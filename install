#!/usr/bin/env sh
echo "Installing your dotfiles..."

# Check if the file does not exist
if [ ! -f ~/.bashrc ]; then
    echo "No .bashrc present. We will create one."
    ln -sv $HOME/.dotfiles/bash/bashrc ~/.bashrc
else
    echo "You've already added your .bashrc"
fi

# Login-shell entry point; just loads .bashrc.
# Installers (Homebrew, python.org, SDKMAN, ...) often create a real ~/.bash_profile,
# so back up any existing real file and replace it with the repo symlink.
if [ -L ~/.bash_profile ]; then
    echo "Your .bash_profile is already linked."
elif [ -e ~/.bash_profile ]; then
    echo "Found an existing .bash_profile; backing it up and linking the repo version."
    mv -v ~/.bash_profile ~/.bash_profile.bak.$(date +%Y%m%d%H%M%S)
    ln -sv $HOME/.dotfiles/bash/bash_profile ~/.bash_profile
else
    echo "No .bash_profile present. We will create one."
    ln -sv $HOME/.dotfiles/bash/bash_profile ~/.bash_profile
fi

echo "Now we're adding application config files..."
# Check if the file does not exist
if [ ! -f ~/.vimrc ]; then
    echo "No .vimrc present. We will create one."
    ln -sv $HOME/.dotfiles/config/vimrc ~/.vimrc
else
    echo "You've already added your .vimrc"
fi

# Check if the git files do not exist
if [ ! -f ~/.gitconfig ]; then
    echo "No .gitconfig present. We will create one."
    ln -sv $HOME/.dotfiles/config/gitconfig ~/.gitconfig
else
    echo "You've already added your .gitconfig"
fi

if [ ! -f ~/.gitignore-global ]; then
    echo "No .gitignore-global present. We will create one."
    ln -sv $HOME/.dotfiles/config/gitignore-global ~/.gitignore-global
else
    echo "You've already added your .gitignore-global"
fi

# Ghostty terminal config (keeps cursor / shell-integration behavior identical across machines)
if [ ! -f ~/.config/ghostty/config ]; then
    echo "No Ghostty config present. We will create one."
    mkdir -p ~/.config/ghostty
    ln -sv $HOME/.dotfiles/config/ghostty ~/.config/ghostty/config
else
    echo "You've already added your Ghostty config"
fi

# Install Homebrew packages from the Brewfile (formulae, casks, VS Code extensions).
echo "Installing Homebrew packages from the Brewfile..."
if command -v brew >/dev/null 2>&1; then
    brew bundle install --file "$HOME/.dotfiles/Brewfile"
else
    echo "Homebrew not found. Install it from https://brew.sh, then re-run this script (or run 'brew bundle install')."
fi

echo "Finished. Isn't this an easier way to keep your dotfiles in sync? 😎"
